generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Pengguna {
  idPengguna     String      @id @default(cuid())
  nama           String
  email          String      @unique
  kataSandi      String
  nomorHp        String?
  peran          Peran       @default(PELANGGAN)
  aktif          Boolean     @default(true)
  dibuatPada     DateTime    @default(now())
  diperbaruiPada DateTime    @updatedAt
  pemesanan      Pemesanan[]

  @@map("pengguna")
}

model Lapangan {
  idLapangan     String         @id @default(cuid())
  nama           String
  deskripsi      String?
  hargaPerJam    Decimal        @db.Decimal(10, 2)
  status         StatusLapangan @default(TERSEDIA)
  dibuatPada     DateTime       @default(now())
  diperbaruiPada DateTime       @updatedAt
  pemesanan      Pemesanan[]
  slotWaktu      Slotwaktu[]

  @@map("lapangan")
}

model Slotwaktu {
  idSlotwaktu  String     @id @default(cuid())
  lapanganId   String
  tanggal      DateTime   @db.Date
  jamMulai     String
  jamSelesai   String
  sudahDipesan Boolean    @default(false)
  diblokir     Boolean    @default(false)
  dibuatPada   DateTime   @default(now())
  pemesanan    Pemesanan?
  lapangan     Lapangan   @relation(fields: [lapanganId], references: [idLapangan], onDelete: Cascade)

  @@unique([lapanganId, tanggal, jamMulai])
  @@map("slot_waktu")
}

model Pemesanan {
  idPemesanan    String          @id @default(cuid())
  kodePemesanan  String          @unique
  penggunaId     String
  lapanganId     String
  slotWaktuId    String          @unique
  totalHarga     Decimal         @db.Decimal(10, 2)
  status         StatusPemesanan @default(MENUNGGU)
  catatan        String?
  rating         Int?
  ulasan         String?
  dibuatPada     DateTime        @default(now())
  diperbaruiPada DateTime        @updatedAt
  pembayaran     Pembayaran?
  lapangan       Lapangan        @relation(fields: [lapanganId], references: [idLapangan])
  pengguna       Pengguna        @relation(fields: [penggunaId], references: [idPengguna])
  slotWaktu      Slotwaktu       @relation(fields: [slotWaktuId], references: [idSlotwaktu])

  @@map("pemesanan")
}

model Pembayaran {
  idPembayaran       String           @id @default(cuid())
  pemesananId        String           @unique
  jumlah             Decimal          @db.Decimal(10, 2)
  metodeBayar        String?
  status             StatusPembayaran @default(MENUNGGU)
  idOrderGateway     String?          @unique
  idTransaksiGateway String?
  responGateway      Json?
  dibayarPada        DateTime?
  kadaluarsaPada     DateTime?
  dibuatPada         DateTime         @default(now())
  pemesanan          Pemesanan        @relation(fields: [pemesananId], references: [idPemesanan])

  @@map("pembayaran")
}

enum Peran {
  PEMILIK
  ADMIN
  PELANGGAN
}

enum StatusLapangan {
  TERSEDIA
  PERAWATAN
  TUTUP
}

enum StatusPemesanan {
  MENUNGGU
  DIKONFIRMASI
  DIBATALKAN
  SELESAI
}

enum StatusPembayaran {
  MENUNGGU
  LUNAS
  GAGAL
}
